{
  "manifest_version": 3,
  "name": "newtab01",
  "version": "0.2.27",
  "minimum_chrome_version": "104",
  "description": "Redesigned new tab page featuring your bookmarks, apps, most visited, and recently closed in a custom layout with split screen and search.",
  "icons": {
    "128": "icons/icon_128.png",
    "48": "icons/icon_48.png",
    "16": "icons/icon_16.png"
  },
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "src/background.ts", "type": "module" },
  "permissions": ["bookmarks", "favicon", "topSites", "tabs", "tabGroups",
                  "storage", "fontSettings", "sessions", "alarms",
                  "contextMenus",
                  "declarativeNetRequest", "search"],
  "host_permissions": ["<all_urls>"],
  "optional_permissions": []
}
